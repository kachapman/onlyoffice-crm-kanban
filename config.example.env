# === Database ===
DB_HOST=db
DB_PORT=5432
DB_NAME=sietch_crm
DB_USER=sietch
DB_PASSWORD=change_me_in_production

# === Dashboard ===
PORT=8766

# Set true when served over HTTPS (production behind nginx + certbot)
COOKIE_SECURE=false

# Secret for signing session cookies (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
COOKIE_SECRET=

# === Telegram Bot (customer deal status) ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# === Telegram Notifications ===
TELEGRAM_NOTIFY_ENABLED=true
TELEGRAM_NOTIFY_POLL_INTERVAL=5
TELEGRAM_NOTIFY_BATCH_SIZE=10

# === SMTP (password reset emails) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME="Sietch CRM"
SMTP_USE_TLS=true

# === Document Server (OnlyOffice) ===
DOCS_JWT_SECRET=change_me_in_production
DOCS_INTERNAL_URL=http://docserver:8080
DOCS_PUBLIC_URL=https://docs.publicadjustermidwest.com

# Dashboard public URL (used for Document Server callbacks and file download URLs)
CRM_PUBLIC_URL=https://dashboard.publicadjustermidwest.com

# === OnlyOffice CRM (transition sync — remove after cutover) ===
# ONLYOFFICE_PORTAL_URL=https://office.publicadjustermidwest.com
# ONLYOFFICE_SSL_VERIFY=true
# SYNC_BOT_EMAIL=bot@your-crm-domain.com
# SYNC_BOT_PASSWORD=your_bot_crm_password

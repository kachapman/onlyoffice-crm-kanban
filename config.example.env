# Your OnlyOffice Community Server / Workspace base URL (no trailing slash)
ONLYOFFICE_PORTAL_URL=https://office.publicadjustermidwest.com

# Dashboard listen port
PORT=8765

# Set to false for self-signed TLS certificates
ONLYOFFICE_SSL_VERIFY=true

# Set true when served over HTTPS (production behind nginx + certbot)
COOKIE_SECURE=false

# Telegram bot for customer deal status (FEAT-023)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# CRM credentials for the bot user (must have access to CRM)
BOT_CRM_EMAIL=bot@your-crm-domain.com
BOT_CRM_PASSWORD=your_bot_crm_password

# Mail scanner (auto process CRM inbox emails)
SCANNER_ENABLED=true
SCANNER_POLL_INTERVAL=120
# Defaults are SAFE (dry-run = no actions). Use the in-app "Behavior" toggles (Mail → Scanner Admin → Behavior) to enable.
# Only set these to true if you want the scanner to create real deals/tasks/notes/notifications on startup.
SCANNER_CREATE_DEALS=false
SCANNER_CREATE_TASKS=false
SCANNER_POST_NOTES=false
SCANNER_NOTIFY_USERS=false

# Stage IDs (CRM — run this in browser console to find yours:
#   fetch("/api/2.0/crm/opportunity/stage").then(r=>r.json()).then(d=>console.log(d.response?.map(s=>s.id+': '+s.title).join('\\n')))
# )
SCANNER_STAGE_NEW_SUPPLEMENT=18
SCANNER_STAGE_FLAT_RATE=17

# User GUIDs (CRM — run: fetch("/api/2.0/people/filter").then(r=>r.json()).then(d=>console.log(d.response.map(u=>u.id+': '+u.displayName).join('\\n')))
# )
SCANNER_USER_KEN=
SCANNER_USER_REBECA=
SCANNER_USER_CLAUDIU=

# Custom field IDs (CRM — run: fetch("/api/2.0/crm/opportunity/customfield/definitions").then(r=>r.json()).then(d=>console.log(d.response.map(f=>f.id+': '+f.fieldName).join('\\n')))
# )
SCANNER_FIELD_CLAIM_NUMBER=11
SCANNER_FIELD_CRM_JOB_ID=26
SCANNER_FIELD_ADDRESS=4

# Task category IDs (CRM — run: fetch("/api/2.0/crm/task/category").then(r=>r.json()).then(d=>console.log(d.response.map(c=>c.id+': '+c.title).join('\\n')))
# )
SCANNER_TASK_CAT_ESTIMATE=34
SCANNER_TASK_CAT_FOLLOW_UP=35

# Remote scanner service (optional). When set, dashboard proxies /api/scanner/* to this URL
# (used when the scanner runs in its own container on the CRM droplet).
# Example: SCANNER_SERVICE_URL=http://159.89.229.126:8787
SCANNER_SERVICE_URL=